{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "canal-saas-dev",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-14",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"directory": "./admin/dist",
		"binding": "ASSETS",
		"not_found_handling": "single-page-application"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "canal-saas-dev-db",
			"database_id": "TODO_CREATE_NEW_D1"
		}
	],
	"vars": {
		"BETTER_AUTH_URL": "http://localhost:8787"
	},
	"alias": {
		"better-auth/adapters/kysely": "./node_modules/better-auth/dist/db/adapter-kysely.mjs"
	},
	"vectorize": [
		{
			"binding": "VECTORIZE",
			"index_name": "canal-saas-dev-vectors"
		}
	],
	"ai": {
		"binding": "AI"
	},
	"r2_buckets": [
		{
			"binding": "MEDIA",
			"bucket_name": "canal-saas-dev-media"
		}
	],
	"queues": {
		"producers": [
			{
				"binding": "QUEUE",
				"queue": "canal-saas-dev-queue"
			}
		],
		"consumers": [
			{
				"queue": "canal-saas-dev-queue",
				"max_batch_size": 10,
				"max_retries": 3,
				"max_batch_timeout": 5
			}
		]
	},
	"triggers": {
		"crons": [
			"0 0 * * SUN"
		]
	},
	"durable_objects": {
		"bindings": [
			{
				"name": "AGENT_DO",
				"class_name": "GabiAgent"
			}
		]
	},
	"migrations": [
		{
			"tag": "v1",
			"new_classes": [
				"GabiAgent"
			]
		}
	],
	"kv_namespaces": [
		{
			"binding": "CANAL_KV",
			"id": "TODO_CREATE_NEW_KV"
		}
	],
	"analytics_engine_datasets": [
		{
			"binding": "ANALYTICS",
			"dataset": "canal_saas_dev_metrics"
		}
	]
}