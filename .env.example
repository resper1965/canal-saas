# Canal SaaS — Environment Variables
# Copy to .dev.vars for local development

# ── Better Auth ──────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-here-min-32-chars
BETTER_AUTH_URL=http://localhost:8787

# ── Admin Bootstrap ──────────────────────────────────
ADMIN_SETUP_KEY=your-setup-key-for-initial-admin

# ── Google OAuth (optional) ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Slack Alerts (optional) ──────────────────────────
SLACK_WEBHOOK_URL=

# ── Resend Email (optional) ──────────────────────────
RESEND_API_KEY=

# ── Note: These are Cloudflare bindings, not env vars ──
# DB             → D1 Database (wrangler.jsonc)
# CANAL_KV       → KV Namespace (wrangler.jsonc)
# MEDIA          → R2 Bucket (wrangler.jsonc)
# VECTORIZE      → Vectorize Index (wrangler.jsonc)
# AI             → Workers AI (wrangler.jsonc)
# ANALYTICS      → Analytics Engine (wrangler.jsonc)
# QUEUE          → Queue (wrangler.jsonc)
# AGENT_DO       → Durable Object (wrangler.jsonc)
# SEND_EMAIL     → Email Workers (wrangler.jsonc)
